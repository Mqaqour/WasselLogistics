# Required environment variables — copy to .env and fill in values

# ── respond.io Custom Channel ─────────────────────────────────────────────────
RESPOND_CHANNEL_ID=
RESPOND_API_TOKEN=
RESPOND_WEBHOOK_URL=https://app.respond.io/custom/channel/webhook/

# ── Microsoft SQL Server ──────────────────────────────────────────────────────
DB_SERVER=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_SERVER_CERTIFICATE=false

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL of the React frontend (used for CORS and Socket.IO)
FRONTEND_URL=https://yourdomain.com
