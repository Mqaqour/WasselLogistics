GEMINI_API_KEY=
VITE_RESPONDIO_CHANNEL_ID=

# Wassel Custom Chat backend URL (used by the frontend ChatWidget)
VITE_CHAT_BACKEND_URL=http://localhost:3001

# respond.io Custom Channel bridge
RESPONDIO_API_TOKEN=
RESPONDIO_CHANNEL_ID=
RESPONDIO_INCOMING_WEBHOOK_URL=https://app.respond.io/custom/channel/webhook/
RESPONDIO_BRIDGE_PORT=8787

# Optional: forward outgoing respond.io messages to your own chat transport
CUSTOM_CHAT_OUTGOING_WEBHOOK_URL=

# QuickRate shipping quotes API (used by the Vite dev proxy — never sent to the browser)
QUICKRATE_API_KEY=
